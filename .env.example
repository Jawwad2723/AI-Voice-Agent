# ─────────────────────────────────────────────────
# Voice AI Agent - Configuration
# ─────────────────────────────────────────────────

# ── LLM Provider Configuration ──
# Choose between "qwen" or "openai"
LLM_PROVIDER=qwen

# Qwen/Ollama Configuration (if using Qwen)
OLLAMA_BASE_URL=http://38.247.189.107:8095/v1
QWEN_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
OLLAMA_API_KEY=mykey

# OpenAI Configuration (if using OpenAI)
# Uncomment and fill if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── Speech Recognition (Deepgram) ──
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Text-to-Speech (ElevenLabs) ──
ELEVENLABS_API_KEY=your-elevenlabs-api-key
LOCAL_ELEVENLABS_VOICE_ID=J2FGlQG8Gd7x8uEDt2H8
# Model: eleven_multilingual_v2 or eleven_multilingual_v3 (v3 supports emotions)
LOCAL_ELEVENLABS_MODEL=eleven_multilingual_v2
# Version: "v2" for standard, "v3" for emotions support (giggles, cough, etc.)
ELEVENLABS_MODEL_VERSION=v2

# ── Scenario-Specific Voice IDs ──
VOICE_APPOINTMENT_REMINDER=epkQ8pqDcY2DxhmFi8xl
VOICE_LEAD_QUALIFICATION=BIvP0GN1cAtSRTxNHnWS
VOICE_CUSTOMER_SURVEY=ljX1ZrXuDIIRVcmiVSyR
VOICE_PAYMENT_FOLLOWUP=bMxLr8fP6hzNRRi9nJxU
VOICE_EVENT_CONFIRMATION=J2FGlQG8Gd7x8uEDt2H8

# ── Agent Configuration ──
# Name of the AI agent (controllable)
AGENT_NAME=Alex

# Default customer name (used instead of "Inbound Caller")
DEFAULT_CUSTOMER_NAME=Jawwad

# ── Asterisk ARI Configuration ──
ASTERISK_HOST=127.0.0.1
ASTERISK_PORT=8088
ASTERISK_ARI_USERNAME=ariuser
ASTERISK_ARI_PASSWORD=aripassword
ASTERISK_ARI_APP=asterisk-ai-voice-agent
ASTERISK_OUTBOUND_ENDPOINT_FORMAT=PJSIP/{phone_number}

# ── Silence Detection & "Are You There?" ──
# Timeout in seconds before asking "Are you there?" (e.g., 5.0 seconds)
SILENCE_TIMEOUT_SECONDS=5.0
# Enable/disable the "Are you there?" prompt (true or false)
ASK_ARE_YOU_THERE=true

# ── Database Configuration ──
# PostgreSQL connection string
# Format: postgresql+psycopg2://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql+psycopg2://username:password@your-host.aivencloud.com:10167/defaultdb?sslmode=require

# ── Recording Configuration ──
# Path to store .wav recordings
RECORDING_DIR=./recordings

# ── Webhook Configuration ──
# Webhook URL for callbacks (ngrok or production URL)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# ── Vapi Configuration (Legacy/Compatibility) ──
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-phone-number-id

# ── RTP Server Configuration ──
RTP_SERVER_HOST=0.0.0.0
RTP_PORT_RANGE_START=18080
RTP_PORT_RANGE_END=18180
