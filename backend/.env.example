# ─────────────────────────────────────────────────────────────────
# Voice AI Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Asterisk ARI Configuration ────────────────────────────────────
ASTERISK_HOST=127.0.0.1
ASTERISK_PORT=8088
ASTERISK_ARI_USERNAME=ariuser
ASTERISK_ARI_PASSWORD=aripassword
ASTERISK_ARI_APP=asterisk-ai-voice-agent
ASTERISK_OUTBOUND_ENDPOINT_FORMAT=PJSIP/{phone_number}

# ── Deepgram STT ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Ollama / Qwen LLM ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://your-ollama-server:8095/v1
QWEN_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
OLLAMA_API_KEY=mykey

# ── ElevenLabs TTS ───────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
LOCAL_ELEVENLABS_VOICE_ID=epkQ8pqDcY2DxhmFi8xl
LOCAL_ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Scenario-Specific Voice IDs ───────────────────────────────────
# Each scenario uses a different ElevenLabs voice / agent persona:
#   appointment_reminder → Aria
#   lead_qualification   → Ethan
#   customer_survey      → Chloe
#   payment_followup     → Marcus
#   event_confirmation   → David
VOICE_APPOINTMENT_REMINDER=epkQ8pqDcY2DxhmFi8xl
VOICE_LEAD_QUALIFICATION=BIvP0GN1cAtSRTxNHnWS
VOICE_CUSTOMER_SURVEY=ljX1ZrXuDIIRVcmiVSyR
VOICE_PAYMENT_FOLLOWUP=bMxLr8fP6hzNRRi9nJxU
VOICE_EVENT_CONFIRMATION=J2FGlQG8Gd7x8uEDt2H8

# ── Default Scenario for Inbound Calls ────────────────────────────
# Scenario applied when a softphone dials in (e.g. Zoiper → 5001)
# Valid values: appointment_reminder | lead_qualification |
#               customer_survey | payment_followup | event_confirmation
DEFAULT_INBOUND_SCENARIO=appointment_reminder

# ── RTP Server Configuration ──────────────────────────────────────
RTP_SERVER_HOST=0.0.0.0
RTP_PORT_RANGE_START=18080
RTP_PORT_RANGE_END=18180
